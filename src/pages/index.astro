---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-4"
       style="background: rgba(250,245,232,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(90,144,80,0.12);">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-xl flex items-center justify-center"
           style="background: #5a9050;">
        <svg viewBox="0 0 32 32" fill="none" class="w-5 h-5">
          <path d="M8 18 C8 11 12 8 16 8 C20 8 24 11 24 18" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <circle cx="12" cy="17" r="1.8" fill="white"/>
          <circle cx="20" cy="17" r="1.8" fill="white"/>
          <path d="M12 22 Q16 25 20 22" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        </svg>
      </div>
      <span class="font-display font-semibold text-lg text-slate-850">SimplySay</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#features" class="text-sm font-body text-slate-700 hover:text-sage-600 transition-colors">Features</a>
      <a href="#how-it-works" class="text-sm font-body text-slate-700 hover:text-sage-600 transition-colors">How it works</a>
      <a href="#waitlist" class="text-sm font-semibold px-4 py-2 rounded-full transition-all"
         style="background: #5a9050; color: white; hover:background: #437039;">
        Join Waitlist
      </a>
    </div>
  </nav>


  <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-28 pb-20 overflow-hidden"
           style="background: linear-gradient(160deg, #faf5e8 0%, #f0f7ee 60%, #e8f4e4 100%);">

    <!-- Background organic shapes -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full opacity-20"
           style="background: radial-gradient(circle, #a8c5a0 0%, transparent 70%);"></div>
      <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full opacity-15"
           style="background: radial-gradient(circle, #7daa72 0%, transparent 70%);"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] opacity-5 rounded-full"
           style="background: radial-gradient(circle, #5a9050 0%, transparent 60%);"></div>
      <!-- Decorative dots grid -->
      <svg class="absolute top-24 left-12 opacity-10" width="160" height="160" viewBox="0 0 160 160">
        {Array.from({length: 64}).map((_, i) => (
          <circle cx={(i % 8) * 22 + 4} cy={Math.floor(i / 8) * 22 + 4} r="2" fill="#5a9050"/>
        ))}
      </svg>
      <svg class="absolute bottom-20 right-16 opacity-10" width="120" height="120" viewBox="0 0 120 120">
        {Array.from({length: 36}).map((_, i) => (
          <circle cx={(i % 6) * 22 + 4} cy={Math.floor(i / 6) * 22 + 4} r="2" fill="#5a9050"/>
        ))}
      </svg>
    </div>

    <!-- Pill badge -->
    <div class="animate-on-scroll mb-8 inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium"
         style="background: rgba(90,144,80,0.1); color: #437039; border: 1px solid rgba(90,144,80,0.2);">
      <span class="w-1.5 h-1.5 rounded-full bg-sage-500 animate-pulse inline-block"></span>
      Coming to iPad — join the waitlist
    </div>

    <!-- Headline -->
    <h1 class="animate-on-scroll font-display text-center text-slate-850 mb-6 leading-tight"
        style="animation-delay: 0.1s; font-size: clamp(2.75rem, 7vw, 5.5rem); max-width: 780px;">
      Every child deserves<br/>
      <em class="not-italic" style="color: #5a9050;">a voice.</em>
    </h1>

    <p class="animate-on-scroll font-body text-center text-slate-700 mb-10 leading-relaxed"
       style="animation-delay: 0.2s; max-width: 520px; font-size: clamp(1rem, 2vw, 1.2rem);">
      SimplySay is an AI-powered AAC app designed for non-verbal and minimally-verbal children and adults — built on motor-planning science, not guesswork.
    </p>

    <!-- CTAs -->
    <div class="animate-on-scroll flex flex-wrap items-center justify-center gap-4 mb-20"
         style="animation-delay: 0.3s;">
      <a href="#waitlist"
         class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-white transition-all hover:shadow-lg hover:-translate-y-0.5"
         style="background: #5a9050; font-size: 1rem;">
        Join the Waitlist
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a href="#"
         class="inline-flex items-center gap-3 px-6 py-3.5 rounded-full font-medium transition-all hover:-translate-y-0.5"
         style="background: white; color: #1e2a23; border: 1.5px solid rgba(30,42,35,0.15); box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
        <svg class="w-5 h-5" viewBox="0 0 22 27" fill="currentColor">
          <path d="M16.2 0c.1 1.5-.4 3-1.4 4.1-1 1.1-2.5 1.8-4 1.7-.1-1.5.5-3 1.5-4C13.3.7 14.8 0 16.2 0zM21 18.8c-.7 1.6-1.1 2.3-2 3.8-1.3 2-3.2 4.4-5.5 4.4-2 0-2.6-1.3-5.4-1.3s-3.5 1.3-5.5 1.3C.4 27-1.6 24.3-3 22c-.1-.2-.2-.3-.2-.5C-3 17.1.2 12.5 3.4 10.2c2.4-1.7 5-2.2 7-1.5.9.3 1.6.8 2.4.8s1.4-.5 2.7-.8c3.5-.9 7.3.4 9 3.9.1.2.2.4.2.6-.1.4-.3 1.7-1.4 3.2l-2.3 2.4z"/>
        </svg>
        App Store (coming soon)
      </a>
    </div>

    <!-- Hero illustration — iPad mockup -->
    <div class="animate-on-scroll relative" style="animation-delay: 0.4s;">
      <div class="relative mx-auto animate-float" style="width: clamp(280px, 60vw, 580px);">
        <!-- iPad outer shell -->
        <div class="relative rounded-[2.5rem] p-3 shadow-2xl"
             style="background: #2a2a2a; box-shadow: 0 40px 80px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.1);">
          <!-- Screen bezel -->
          <div class="rounded-[2rem] overflow-hidden" style="background: #1a1a1a; aspect-ratio: 4/3;">
            <!-- App screen -->
            <div class="w-full h-full" style="background: #f0f7ee;">
              <!-- App header strip -->
              <div class="flex items-center px-3 py-2 gap-2" style="background: #1e2a23; height: 40px;">
                <div class="flex gap-1.5 flex-1">
                  {['I want', 'I feel', 'Help', 'Stop'].map((label, i) => (
                    <div class="flex-1 rounded-md flex items-center justify-center text-white font-bold"
                         style={{
                           fontSize: '8px',
                           height: '24px',
                           background: ['#5a9050','#e8a250','#7daa72','#c0392b'][i]
                         }}>
                      {label}
                    </div>
                  ))}
                </div>
                <div class="rounded-md px-2 flex items-center justify-center text-white font-bold"
                     style="font-size: 8px; height: 24px; background: #437039; min-width: 48px;">
                  SPEAK
                </div>
              </div>
              <!-- Vocab grid -->
              <div class="grid p-2 gap-1.5" style="grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(3, 1fr); flex: 1; height: calc(100% - 40px);">
                {[
                  { label: 'eat', color: '#fef9c3', border: '#ca8a04' },
                  { label: 'drink', color: '#fef9c3', border: '#ca8a04' },
                  { label: 'play', color: '#dcfce7', border: '#16a34a' },
                  { label: 'more', color: '#dcfce7', border: '#16a34a' },
                  { label: 'no', color: '#fee2e2', border: '#dc2626' },
                  { label: 'mom', color: '#ffedd5', border: '#ea580c' },
                  { label: 'dad', color: '#ffedd5', border: '#ea580c' },
                  { label: 'big', color: '#dbeafe', border: '#2563eb' },
                  { label: 'happy', color: '#dbeafe', border: '#2563eb' },
                  { label: 'yes', color: '#dcfce7', border: '#16a34a' },
                  { label: 'go', color: '#dcfce7', border: '#16a34a' },
                  { label: 'stop', color: '#fee2e2', border: '#dc2626' },
                  { label: '', color: '#f3f4f6', border: '#d1d5db', hidden: true },
                  { label: 'like', color: '#dbeafe', border: '#2563eb' },
                  { label: 'home', color: '#fce7f3', border: '#db2777' },
                ].map(btn => (
                  <div class="rounded-lg flex items-center justify-center font-bold transition-all"
                       style={{
                         background: btn.hidden ? '#e5e7eb' : btn.color,
                         border: `1.5px solid ${btn.border || '#d1d5db'}`,
                         fontSize: '9px',
                         opacity: btn.hidden ? '0.3' : '1',
                         color: '#1e2a23',
                         aspectRatio: '1',
                       }}>
                    {btn.label}
                  </div>
                ))}
              </div>
            </div>
          </div>
          <!-- Home button indicator -->
          <div class="absolute bottom-1 left-1/2 -translate-x-1/2 w-20 h-1 rounded-full"
               style="background: rgba(255,255,255,0.3);"></div>
        </div>
        <!-- Glow behind iPad -->
        <div class="absolute inset-0 -z-10 rounded-[3rem] blur-3xl opacity-30"
             style="background: radial-gradient(ellipse, #5a9050, transparent); transform: scale(0.9) translateY(10%);"></div>
      </div>
    </div>
  </section>


  <!-- ─── SOCIAL PROOF STRIP ────────────────────────────────────────────── -->
  <div class="py-10 px-6 border-y" style="background: white; border-color: rgba(90,144,80,0.12);">
    <p class="text-center font-body text-sm font-medium mb-6" style="color: #7daa72; letter-spacing: 0.08em; text-transform: uppercase;">
      Designed with input from
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 opacity-50">
      {['Speech-Language Pathologists', 'AAC Specialists', 'Special Education Teachers', 'Parents & Caregivers'].map(label => (
        <span class="text-slate-700 font-medium text-sm">{label}</span>
      ))}
    </div>
  </div>


  <!-- ─── PROBLEM / SOLUTION ────────────────────────────────────────────── -->
  <section id="how-it-works" class="py-28 px-6" style="background: #faf5e8;">
    <div class="max-w-6xl mx-auto">

      <div class="animate-on-scroll text-center mb-20">
        <span class="inline-block text-sm font-medium px-4 py-1.5 rounded-full mb-4"
              style="background: rgba(90,144,80,0.1); color: #437039;">The Problem</span>
        <h2 class="font-display text-slate-850 mb-4"
            style="font-size: clamp(2rem, 4vw, 3rem);">
          What other AAC apps<br/>get wrong
        </h2>
        <p class="font-body text-slate-600 max-w-xl mx-auto" style="font-size: 1.05rem; line-height: 1.7;">
          Most AAC apps were designed for clinicians to configure — not for the actual moments of communication. SimplySay changes that.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Problems column -->
        <div class="animate-on-scroll flex flex-col gap-4">
          <div class="mb-2 flex items-center gap-2">
            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0"
                 style="background: #fee2e2;">
              <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-700 text-sm uppercase tracking-wide">The old way</h3>
          </div>
          {[
            ['Vocabulary overload on day one', 'Hundreds of buttons, none in the right place, child overwhelmed immediately.'],
            ['Buttons shift when you add words', 'Motor memory destroyed every time a caregiver adds vocabulary.'],
            ['Setup requires an SLP or hours', 'Complex configuration trees that no parent has time to learn.'],
            ['No scaffolding for learning', 'The app speaks, but never teaches. Growth stalls.'],
            ['Robot voices', 'Text-to-speech that sounds nothing like a real child — stigmatizing, not empowering.'],
            ['No growth data', 'How do you know if it\'s working? You don\'t.'],
          ].map(([title, desc]) => (
            <div class="rounded-2xl p-5 flex gap-4" style="background: white; border: 1px solid rgba(220,38,38,0.12);">
              <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                   style="background: #fee2e2;">
                <svg class="w-4 h-4" fill="none" stroke="#dc2626" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M12 3a9 9 0 100 18A9 9 0 0012 3z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-slate-850 text-sm mb-1">{title}</p>
                <p class="text-slate-500 text-sm leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Solutions column -->
        <div class="animate-on-scroll flex flex-col gap-4" style="transition-delay: 0.15s;">
          <div class="mb-2 flex items-center gap-2">
            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0"
                 style="background: #dcfce7;">
              <svg class="w-3.5 h-3.5" fill="none" stroke="#16a34a" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-700 text-sm uppercase tracking-wide">The SimplySay way</h3>
          </div>
          {[
            ['Hidden grid — start small, grow intentionally', 'Full grid positions reserved. 85% hidden at first. Reveal vocabulary only when the child is ready.'],
            ['Fixed-position grid. Forever.', 'Hidden ≠ absent. Every word lives at one address. Motor memory is never broken.'],
            ['AI Smart-Fill + 3-question On-Ramp', 'Answer three questions about your child. SimplySay builds a personalized starter board.'],
            ['Smart-Scaffold prompting', 'Timed visual cues, dimming, and Modeling Mode coach communicators — and partners.'],
            ['High-quality neural TTS', 'Natural, expressive voices via ElevenLabs. Human-sounding, age-appropriate.'],
            ['Communication Diary & MLU tracking', 'Log every session. Track mean length of utterance. See growth over time.'],
          ].map(([title, desc]) => (
            <div class="rounded-2xl p-5 flex gap-4" style="background: white; border: 1px solid rgba(90,144,80,0.18);">
              <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                   style="background: #dcfce7;">
                <svg class="w-4 h-4" fill="none" stroke="#16a34a" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-slate-850 text-sm mb-1">{title}</p>
                <p class="text-slate-500 text-sm leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ─── FEATURES ─────────────────────────────────────────────────────── -->
  <section id="features" class="py-28 px-6 relative overflow-hidden"
           style="background: linear-gradient(180deg, #f0f7ee 0%, #e8f4e4 100%);">

    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 opacity-20 rounded-full"
           style="background: radial-gradient(circle, #a8c5a0, transparent); transform: translate(30%, -30%);"></div>
    </div>

    <div class="max-w-6xl mx-auto relative">
      <div class="animate-on-scroll text-center mb-16">
        <span class="inline-block text-sm font-medium px-4 py-1.5 rounded-full mb-4"
              style="background: rgba(90,144,80,0.15); color: #437039;">Core Features</span>
        <h2 class="font-display text-slate-850" style="font-size: clamp(2rem, 4vw, 3rem);">
          Built different.<br/>On purpose.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
            title: 'Motor Memory First',
            desc: 'A button\'s location is its address. Words never move — ever. Motor-planning consistency is the foundation of AAC fluency.',
            accent: '#5a9050',
            bg: 'rgba(90,144,80,0.08)',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
            title: 'AI Smart-Fill',
            desc: 'Answer 3 questions about your child. SimplySay\'s AI builds a personalized vocabulary board — no SLP required to get started.',
            accent: '#e8a250',
            bg: 'rgba(232,162,80,0.08)',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
            title: 'Grows With Them',
            desc: 'Start with 8 words. Reveal more as the child is ready. The grid never breaks — new vocabulary finds its permanent home.',
            accent: '#7daa72',
            bg: 'rgba(125,170,114,0.1)',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636a9 9 0 010 12.728M15.536 8.464a5 5 0 010 7.072M6.343 6.343a8 8 0 000 11.314M9.172 9.172a4 4 0 000 5.656M12 12h.01"/>`,
            title: 'Never Loses Their Voice',
            desc: 'Fully offline. No WiFi needed. A child\'s ability to communicate should never depend on signal strength.',
            accent: '#437039',
            bg: 'rgba(67,112,57,0.08)',
          },
        ].map((f, i) => (
          <div class="animate-on-scroll rounded-3xl p-7 flex flex-col gap-5 hover:-translate-y-1 transition-transform"
               style={`background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06); transition-delay: ${i * 0.08}s;`}>
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center"
                 style={`background: ${f.bg};`}>
              <svg class="w-6 h-6" fill="none" stroke={f.accent} viewBox="0 0 24 24">
                <Fragment set:html={f.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-display font-semibold text-slate-850 text-lg mb-2">{f.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── SCREENSHOTS ───────────────────────────────────────────────────── -->
  <section class="py-28 px-6 overflow-hidden" style="background: #faf5e8;">
    <div class="max-w-6xl mx-auto">
      <div class="animate-on-scroll text-center mb-16">
        <span class="inline-block text-sm font-medium px-4 py-1.5 rounded-full mb-4"
              style="background: rgba(90,144,80,0.1); color: #437039;">In the App</span>
        <h2 class="font-display text-slate-850" style="font-size: clamp(2rem, 4vw, 3rem);">
          Designed for clarity.<br/>Tested in real life.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          { label: 'Home Board', sublabel: 'Core vocabulary always visible', bg: '#1e2a23' },
          { label: 'On-Ramp Wizard', sublabel: '3 questions to a personalized board', bg: '#2d4a37' },
          { label: 'Growth Report', sublabel: 'Track MLU and communication milestones', bg: '#243b2a' },
        ].map((screen, i) => (
          <div class="animate-on-scroll flex flex-col items-center gap-4" style={`transition-delay: ${i * 0.1}s;`}>
            <!-- iPad frame -->
            <div class="relative w-full rounded-[2rem] p-2.5 shadow-xl"
                 style={`background: ${screen.bg}; max-width: 300px; margin: 0 auto;`}>
              <div class="rounded-[1.4rem] overflow-hidden relative"
                   style="aspect-ratio: 4/3; background: #f0f7ee;">
                <!-- Screen content placeholder -->
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-6">
                  <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-2"
                       style="background: rgba(90,144,80,0.15);">
                    <svg class="w-6 h-6" fill="none" stroke="#5a9050" viewBox="0 0 24 24">
                      {i === 0 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>}
                      {i === 1 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>}
                      {i === 2 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>}
                    </svg>
                  </div>
                  <!-- Mini grid for home board -->
                  {i === 0 && (
                    <div class="grid grid-cols-4 gap-1 w-full">
                      {['eat','drink','play','more','mom','dad','go','stop','big','happy','yes','no'].map((w, j) => (
                        <div class="rounded-md text-center py-1 font-semibold"
                             style={{
                               fontSize: '7px',
                               background: ['#fef9c3','#fef9c3','#dcfce7','#dcfce7','#ffedd5','#ffedd5','#dcfce7','#fee2e2','#dbeafe','#dbeafe','#dcfce7','#fee2e2'][j],
                               color: '#1e2a23',
                             }}>
                          {w}
                        </div>
                      ))}
                    </div>
                  )}
                  {i === 1 && (
                    <div class="flex flex-col gap-2 w-full">
                      {["What's your child's name?", "What do they love most?", "What's the hardest part of your day?"].map((q, j) => (
                        <div class="rounded-lg px-3 py-2 text-center" style="background: white; border: 1px solid rgba(90,144,80,0.2); font-size: '8px'; color: '#1e2a23';">
                          <p style="font-size: 8px; color: '#5a9050'; font-weight: 600; margin: 0;">{`Step ${j+1}`}</p>
                          <p style="font-size: 7px; color: '#374151'; margin: 0;">{q}</p>
                        </div>
                      ))}
                    </div>
                  )}
                  {i === 2 && (
                    <div class="flex flex-col gap-2 w-full">
                      {[['Total words', '1,247'], ['Avg MLU', '2.4'], ['Streak', '12 days']].map(([label, val]) => (
                        <div class="flex justify-between items-center rounded-lg px-3 py-2"
                             style="background: white; border: 1px solid rgba(90,144,80,0.2);">
                          <span style="font-size: 8px; color: '#6b7280';">{label}</span>
                          <span style="font-size: 9px; font-weight: 700; color: '#5a9050';">{val}</span>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </div>
              <div class="h-1 w-16 mx-auto mt-1 rounded-full opacity-30" style="background: white;"></div>
            </div>
            <div class="text-center">
              <p class="font-semibold text-slate-850 text-sm">{screen.label}</p>
              <p class="text-slate-500 text-xs mt-0.5">{screen.sublabel}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── QUOTE / PHILOSOPHY ───────────────────────────────────────────── -->
  <section class="py-24 px-6" style="background: #1e2a23;">
    <div class="max-w-3xl mx-auto text-center animate-on-scroll">
      <svg class="w-10 h-10 mx-auto mb-8 opacity-40" fill="#a8c5a0" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
      </svg>
      <blockquote class="font-display text-white mb-8 leading-relaxed"
                  style="font-size: clamp(1.5rem, 3vw, 2.2rem); font-style: italic;">
        "The app is a co-therapist, not a toy. Every feature must have a communicative rationale."
      </blockquote>
      <p class="text-sage-300 text-sm font-medium tracking-wide uppercase">SimplySay Design Principle #3</p>
    </div>
  </section>


  <!-- ─── WAITLIST ─────────────────────────────────────────────────────── -->
  <section id="waitlist" class="py-28 px-6 relative overflow-hidden"
           style="background: linear-gradient(135deg, #f0f7ee 0%, #faf5e8 50%, #f4ecd4 100%);">

    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full opacity-20"
           style="background: radial-gradient(circle, #a8c5a0, transparent);"></div>
      <div class="absolute -top-16 right-0 w-64 h-64 rounded-full opacity-15"
           style="background: radial-gradient(circle, #7daa72, transparent); transform: translateX(30%);"></div>
    </div>

    <div class="max-w-2xl mx-auto relative text-center animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium mb-6"
           style="background: rgba(90,144,80,0.1); color: #437039; border: 1px solid rgba(90,144,80,0.2);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        Coming to iPad first
      </div>

      <h2 class="font-display text-slate-850 mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">
        Be the first to know<br/>when SimplySay is available.
      </h2>
      <p class="text-slate-600 mb-10 leading-relaxed" style="font-size: 1.05rem;">
        We're building this carefully — with families and clinicians. Join the waitlist to get early access, share your story, and help shape the app.
      </p>

      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4"
            onsubmit="handleWaitlist(event)">
        <input
          type="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-5 py-4 rounded-full font-body text-sm focus:outline-none focus:ring-2 focus:ring-sage-400"
          style="background: white; border: 1.5px solid rgba(90,144,80,0.25); color: #1e2a23;"
          id="waitlist-email"
        />
        <button
          type="submit"
          class="px-8 py-4 rounded-full font-semibold text-white text-sm transition-all hover:shadow-lg hover:-translate-y-0.5"
          style="background: #5a9050; white-space: nowrap;"
        >
          Join Waitlist
        </button>
      </form>
      <p class="text-slate-400 text-xs" id="waitlist-msg">No spam. Unsubscribe anytime. We respect your privacy.</p>
    </div>
  </section>


  <!-- ─── FOOTER ───────────────────────────────────────────────────────── -->
  <footer class="py-12 px-6" style="background: #141e18; border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <!-- Logo -->
        <div class="flex items-center gap-2.5">
          <div class="w-7 h-7 rounded-xl flex items-center justify-center" style="background: #5a9050;">
            <svg viewBox="0 0 32 32" fill="none" class="w-4 h-4">
              <path d="M8 18 C8 11 12 8 16 8 C20 8 24 11 24 18" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <circle cx="12" cy="17" r="1.8" fill="white"/>
              <circle cx="20" cy="17" r="1.8" fill="white"/>
              <path d="M12 22 Q16 25 20 22" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            </svg>
          </div>
          <span class="font-display text-white font-semibold">SimplySay</span>
        </div>

        <!-- Links -->
        <div class="flex items-center gap-8">
          <a href="mailto:danfspam@gmail.com" class="text-sm transition-colors"
             style="color: rgba(255,255,255,0.4); hover:color: rgba(255,255,255,0.8);">
            Contact
          </a>
          <a href="#" class="text-sm transition-colors"
             style="color: rgba(255,255,255,0.4);">Privacy Policy</a>
          <a href="#" class="text-sm transition-colors"
             style="color: rgba(255,255,255,0.4);">Terms</a>
        </div>

        <!-- Copyright -->
        <p class="text-sm" style="color: rgba(255,255,255,0.3);">
          SimplySay &copy; 2026
        </p>
      </div>
    </div>
  </footer>


  <!-- ─── WAITLIST SCRIPT ──────────────────────────────────────────────── -->
  <script is:inline>
    function handleWaitlist(e) {
      e.preventDefault();
      const email = document.getElementById('waitlist-email').value;
      const msg = document.getElementById('waitlist-msg');
      // Replace this with your actual form submission (Resend, Mailchimp, etc.)
      msg.textContent = `✓ You're on the list! We'll be in touch at ${email}`;
      msg.style.color = '#5a9050';
      msg.style.fontWeight = '500';
      document.getElementById('waitlist-email').value = '';
    }
  </script>

</Layout>
